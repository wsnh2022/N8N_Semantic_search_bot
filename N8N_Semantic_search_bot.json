        "jsCode": "const vector = $input.item.json.embedding.values;\nconst chat_id = $('Telegram Trigger').item.json.message.chat.id;\nreturn [{ json: { vector, chat_id } }];"
      },
      "id": "5938b104-b862-4ef6-b010-f1104f46d39b",
