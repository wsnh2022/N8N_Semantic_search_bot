      "typeVersion": 4.2,
      "position": [
        -288,
        -352
      ]
    },
    {
      "parameters": {
        "jsCode": "const vector = $input.item.json.embedding.values;\nconst prev = $('Extract Store Text').item.json;\nreturn [{ json: { vector, text: prev.text, chat_id: prev.chat_id, id: Date.now() } }];"
      },
      "id": "b77b9221-e3cc-4a2b-81ae-6db83dbd6e84",
