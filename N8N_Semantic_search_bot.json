      "name": "Store or Search",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        -768,
        -320
      ]
    },
    {
      "parameters": {
        "jsCode": "const msg = $input.item.json.message.text || '';\nconst text = msg.replace(/^\\/store\\s+/, '').trim();\nconst chat_id = $input.item.json.message.chat.id;\nif (!text) return [{ json: { error: true, chat_id, text: '' } }];\nreturn [{ json: { text, chat_id } }];"
      },
      "id": "f2ea1f22-17c1-4460-b8ea-8fcef560ee8d",
      "name": "Extract Store Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -512,
        -352
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-embedding-001:embedContent?key=YOUR_GEMINI_API_KEY",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ content: { parts: [{ text: $json.text }] } }) }}",
        "options": {}
      },
      "id": "738d1788-3bfb-4b6e-8003-344f0d6014e9",
      "name": "Gemini Embed Store",
