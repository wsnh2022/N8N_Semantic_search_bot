      ]
    },
    {
      "parameters": {
        "jsCode": "const results = $input.item.json.result;\nconst chat_id = $('Prepare Search Payload').item.json.chat_id;\n\nif (!results || results.length === 0) {\n  return [{ json: { reply: 'No matching results found.', chat_id } }];\n}\n\nconst top = results[0];\nconst score = (top.score * 100).toFixed(1);\nconst text = top.payload.text;\n\nreturn [{ json: { reply: 'Best match (' + score + '% similarity):\\n\\n' + text, chat_id } }];"
      },
